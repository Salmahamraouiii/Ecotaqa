# Environment Variables for Real Energy Data Integration

# ============================================
# EIA (U.S. Energy Information Administration)
# ============================================
# Get your free API key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ============================================
# Electricity Maps
# ============================================
# Get API key at: https://www.electricitymaps.com/
# Free tier available for developers
ELECTRICITY_MAPS_API_KEY=your_electricity_maps_api_key_here

# ============================================
# WattTime (Optional)
# ============================================
# Register at: https://www.watttime.org/api-documentation/
WATTTIME_USERNAME=your_username
WATTTIME_PASSWORD=your_password

# ============================================
# MQTT Configuration (Optional - for IoT meters)
# ============================================
ENABLE_MQTT=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ============================================
# Data Source Configuration
# ============================================
# Which data source to use: mock, eia, electricity-maps, hybrid
DATA_SOURCE=hybrid

# ============================================
# Existing Configuration
# ============================================
DATABASE_URL="file:./dev.db"
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-key-here
