// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite doesn't support enums, using String instead
// Valid values for role: "USER", "COMPANY", "ADMIN"
// Valid values for status: "LOW", "MEDIUM", "HIGH", "CRITICAL"

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String   // Hashed
  name          String?
  role          String   @default("USER")
  energyScore   Int      @default(100)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  companyId     String?
  company       Company? @relation(fields: [companyId], references: [id])
  alerts        Alert[]
  consumption   Consumption[]
  
  // Gamification & Education
  points        Int      @default(0)
  badges        UserBadge[]
  lessons       UserLesson[]
}

model Company {
  id            String   @id @default(uuid())
  name          String
  industry      String?
  subscription  String   @default("FREE")
  createdAt     DateTime @default(now())

  // Relations
  users         User[]
  buildings     Building[]
  goals         Goal[]
}

model Building {
  id            String   @id @default(uuid())
  name          String
  address       String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  
  departments   Department[]
  consumption   Consumption[]
}

model Department {
  id            String   @id @default(uuid())
  name          String
  buildingId    String
  building      Building @relation(fields: [buildingId], references: [id])
  
  consumption   Consumption[]
}

model Region {
  id            String       @id @default(uuid())
  name          String       @unique
  latitude      Float
  longitude     Float
  status        String   @default("LOW")
  
  consumption   Consumption[]
}

model Consumption {
  id            String   @id @default(uuid())
  value         Float    // In kWh
  cost          Float?   // Estimated cost
  timestamp     DateTime @default(now())
  
  // Relations - Can belong to a User, Building, Department, or Region
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  
  buildingId    String?
  building      Building? @relation(fields: [buildingId], references: [id])
  
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  
  regionId      String?
  region        Region?  @relation(fields: [regionId], references: [id])
}

model Alert {
  id            String   @id @default(uuid())
  message       String
  type          String   // e.g., "SPIKE", "WASTE", "GOAL"
  severity      String   // "INFO", "WARNING", "CRITICAL"
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  userId        String
  user          User     @relation(fields: [userId], references: [id])
}

// Gamification Models

model Badge {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String
  iconUrl       String?
  createdAt     DateTime @default(now())
  
  users         UserBadge[]
}

model UserBadge {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  badgeId       String
  badge         Badge    @relation(fields: [badgeId], references: [id])
  awardedAt     DateTime @default(now())
  
  @@unique([userId, badgeId])
}

// Sustainability Goals

model Goal {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  
  type          String   // e.g., "REDUCTION", "EFFICIENCY", "RENEWABLE"
  targetValue   Float
  currentValue  Float    @default(0)
  unit          String   // "kWh", "%", "CO2"
  
  startDate     DateTime
  endDate       DateTime
  status        String   @default("ACTIVE") // "ACTIVE", "COMPLETED", "FAILED"
  
  updatedAt     DateTime @updatedAt
}

// Educational Content

model Tip {
  id            String   @id @default(uuid())
  title         String
  content       String
  category      String   // "Home", "Office", "Industrial"
  audience      String   @default("USER") // Target audience
  createdAt     DateTime @default(now())
}

model Lesson {
  id            String   @id @default(uuid())
  title         String
  content       String   // Could be markdown or link to video
  pointsReward  Int      @default(10)
  createdAt     DateTime @default(now())
  
  users         UserLesson[]
}

model UserLesson {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id])
  completedAt   DateTime @default(now())
  
  @@unique([userId, lessonId])
}
